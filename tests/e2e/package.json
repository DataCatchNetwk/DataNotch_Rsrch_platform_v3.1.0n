{
  "name": "@datanotch/e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end cloud tests for the DataNotch Research Platform",
  "scripts": {
    "test:cloud": "playwright test --config=playwright.cloud.config.ts",
    "test:cloud:headed": "playwright test --config=playwright.cloud.config.ts --headed",
    "test:cloud:debug": "playwright test --config=playwright.cloud.config.ts --debug",
    "install:browsers": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.0.0"
  }
}
