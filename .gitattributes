# Normalize text files and keep repository line endings consistent.
* text=auto eol=lf

# Windows-native scripts should keep CRLF for compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should stay LF.
*.sh text eol=lf

# Common binary assets (never normalize line endings).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.dbf binary
*.shp binary
*.shx binary
*.docx binary
*.xlsx binary
*.pptx binary
