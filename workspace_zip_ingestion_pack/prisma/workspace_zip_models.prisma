// Add these models to your existing Prisma schema.prisma

enum WorkspaceFileKind {
  FOLDER
  FILE
  ARCHIVE
}

enum WorkspaceArchiveStatus {
  UPLOADED
  SCANNED
  EXTRACTED
  FAILED
}

enum DatasetRegistryStage {
  RAW
  CLEAN
  HARMONIZED
  FEATURE_SET
}

model WorkspaceArchive {
  id              String                 @id @default(cuid())
  workspaceId     String
  uploadedById    String?
  archiveName     String
  archivePath     String
  checksumSha256  String
  status          WorkspaceArchiveStatus @default(UPLOADED)
  fileCount       Int                    @default(0)
  extractedBytes  BigInt                 @default(0)
  errorMessage    String?
  createdAt       DateTime               @default(now())
  extractedAt     DateTime?
}

model WorkspaceFile {
  id                  String            @id @default(cuid())
  workspaceId          String
  archiveId            String?
  parentId             String?
  kind                 WorkspaceFileKind
  name                 String
  relativePath         String
  storagePath          String
  mimeType             String?
  extension            String?
  sizeBytes            BigInt           @default(0)
  checksumSha256       String?
  isDatasetCandidate   Boolean          @default(false)
  datasetId            String?
  metadataJson         Json?
  createdAt            DateTime         @default(now())

  @@index([workspaceId])
  @@index([archiveId])
  @@index([parentId])
}

model DatasetRegistryRecord {
  id                  String               @id @default(cuid())
  workspaceId          String
  sourceWorkspaceFileId String?
  name                String
  description         String?
  stage               DatasetRegistryStage @default(RAW)
  status              String               @default("REGISTERED")
  version             String               @default("v1.0")
  records             Int                  @default(0)
  variables           Int                  @default(0)
  qualityScore        Float?
  storagePath         String?
  lineageJson         Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([workspaceId])
  @@index([stage])
}

model DataPreparationJob {
  id          String   @id @default(cuid())
  workspaceId String
  datasetId   String
  stage       String
  status      String   @default("QUEUED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
