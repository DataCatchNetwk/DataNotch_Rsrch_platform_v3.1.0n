generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RESEARCHER
  DATA_STEWARD
  REVIEWER
  USER
}

enum ThreadStatus {
  OPEN
  PENDING_REVIEW
  CLOSED
  ESCALATED
}

enum AssetType {
  PROJECT
  STUDY
  DATASET
  ANALYSIS
  PUBLICATION
  SYSTEM
  SUPPORT
  NONE
}

enum MessageFolder {
  INBOX
  SENT
  DRAFT
  ARCHIVED
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RoomType {
  R_MEET_AUDIO
  R_ZOOMA_VIDEO
  STUDY_REVIEW
  DATASET_REVIEW
  ANALYSIS_REVIEW
  PUBLICATION_REVIEW
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model PlatformUser {
  id          String   @id @default(cuid())
  fullName    String
  email       String   @unique
  phone       String?
  role        UserRole @default(USER)
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  createdThreads InboxThread[] @relation("CreatedThreads")
  sentMessages   InboxMessage[]
  participants   InboxParticipant[]
  notifications  Notification[]
  tickets        SupportTicket[]
  roomsCreated   MeetingRoom[] @relation("RoomsCreated")
}

model InboxThread {
  id          String         @id @default(cuid())
  subject     String
  createdById String
  assetType   AssetType      @default(NONE)
  assetId     String?
  status      ThreadStatus   @default(OPEN)
  priority    MessagePriority @default(NORMAL)
  isBroadcast Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy    PlatformUser @relation("CreatedThreads", fields: [createdById], references: [id])
  messages     InboxMessage[]
  participants InboxParticipant[]
  meetingInvites MeetingInvitation[]
}

model InboxMessage {
  id            String        @id @default(cuid())
  threadId      String
  senderId      String
  body          String
  attachmentUrl String?
  folder        MessageFolder @default(INBOX)
  isEmailCopy   Boolean       @default(false)
  externalEmail String?
  isRead        Boolean       @default(false)
  createdAt     DateTime      @default(now())

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender PlatformUser @relation(fields: [senderId], references: [id])
}

model InboxParticipant {
  id         String   @id @default(cuid())
  threadId   String
  userId     String
  role       String   @default("participant")
  lastReadAt DateTime?
  muted      Boolean  @default(false)

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   PlatformUser @relation(fields: [userId], references: [id])

  @@unique([threadId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("SYSTEM")
  assetType AssetType @default(SYSTEM)
  assetId   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MeetingRoom {
  id          String   @id @default(cuid())
  title       String
  roomType    RoomType
  assetType   AssetType @default(NONE)
  assetId     String?
  createdById String
  isLive      Boolean  @default(false)
  startedAt   DateTime?
  endedAt     DateTime?
  recordingUrl String?
  transcript  String?
  aiSummary   String?
  createdAt   DateTime @default(now())

  createdBy PlatformUser @relation("RoomsCreated", fields: [createdById], references: [id])
  invitations MeetingInvitation[]
  records MeetingRecord[]
}

model MeetingInvitation {
  id        String   @id @default(cuid())
  threadId  String?
  roomId    String
  userId    String
  email     String
  status    String   @default("PENDING")
  startsAt  DateTime?
  createdAt DateTime @default(now())

  thread InboxThread? @relation(fields: [threadId], references: [id])
  room   MeetingRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model MeetingRecord {
  id        String   @id @default(cuid())
  roomId    String
  kind      String
  url       String?
  content   String?
  createdAt DateTime @default(now())

  room MeetingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String       @id @default(cuid())
  requesterId String
  subject     String
  category    String
  status      TicketStatus @default(OPEN)
  priority    MessagePriority @default(NORMAL)
  threadId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester PlatformUser @relation(fields: [requesterId], references: [id])
}
