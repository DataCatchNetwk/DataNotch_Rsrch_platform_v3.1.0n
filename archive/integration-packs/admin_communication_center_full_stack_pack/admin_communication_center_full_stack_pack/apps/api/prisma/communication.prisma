model CommunicationRoom {
  id               String   @id @default(cuid())
  name             String
  mode             String
  type             String
  status           String   @default("ACTIVE")
  workspaceId      String?
  studyId          String?
  participantCount Int      @default(0)
  unreadCount      Int      @default(0)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  participants CommunicationParticipant[]
  messages     CommunicationMessage[]
  events       CommunicationEvent[]
}

model CommunicationParticipant {
  id          String   @id @default(cuid())
  roomId      String
  displayName String
  role        String   @default("GUEST")
  status      String   @default("ONLINE")
  joinedAt    DateTime @default(now())

  room CommunicationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model CommunicationMessage {
  id        String   @id @default(cuid())
  roomId    String
  body      String
  senderId  String?
  createdAt DateTime @default(now())

  room CommunicationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model CommunicationEvent {
  id        String   @id @default(cuid())
  roomId    String?
  type      String
  severity  String   @default("INFO")
  message   String
  actorId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  room CommunicationRoom? @relation(fields: [roomId], references: [id], onDelete: SetNull)
}
