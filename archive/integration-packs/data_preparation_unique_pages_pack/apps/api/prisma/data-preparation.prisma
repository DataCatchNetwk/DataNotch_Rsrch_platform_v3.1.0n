model DataPreparationJob {
  id          String   @id @default(cuid())
  datasetId   String
  stage       String
  status      String   @default("queued")
  metrics     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DataPreparationResult {
  id          String   @id @default(cuid())
  jobId       String
  datasetId   String
  stage       String
  result      Json
  createdAt   DateTime @default(now())
}

model DatasetVersionRelease {
  id          String   @id @default(cuid())
  datasetId   String
  version     String
  stage       String
  notes       String?
  locked      Boolean  @default(false)
  schemaDiff  Json?
  rowDiff     Json?
  createdAt   DateTime @default(now())
}

model DatabaseStudioHandoff {
  id                 String   @id @default(cuid())
  sourceConnectionId String
  datasetId          String
  datasetName        String
  sql                String
  status             String   @default("registered-for-profiling")
  createdAt          DateTime @default(now())
}
