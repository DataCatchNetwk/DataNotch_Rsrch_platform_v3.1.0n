generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ProcessedStatus {
  PENDING
  PROCESSED
  FAILED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  RESEARCHER
  VIEWER
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum DatasetVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
  RESTRICTED
}

enum AnalysisJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ReportStatus {
  DRAFT
  READY
  ARCHIVED
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_REVIEWED
  REQUEST_COMMENT
  DATASET_ADDED
  REPORT_CREATED
  MEMBER_ADDED
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
}

enum PipelineRunStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  PARTIAL_SUCCESS
}

enum PipelineStepStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELED
}

enum PipelineStepType {
  INGEST
  PROFILE
  VALIDATE
  CLEAN
  TRANSFORM
  FEATURE_ENGINEERING
  SPLIT
  TRAIN
  EVALUATE
  EXPLAIN
  CHART
  REPORT
  EXPORT
  PUBLISH
}

enum WorkerJobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  RETRYING
  CANCELED
}

enum ArtifactKind {
  DATASET
  CLEANED_DATASET
  FEATURE_SET
  MODEL
  METRICS
  CHART
  REPORT
  EXPORT_PACKAGE
  LOG
}

model User {
  id                 String      @id @default(cuid()) @db.VarChar(30)
  firstname          String      @db.VarChar(100)
  surname            String      @db.VarChar(100)
  email              String      @unique @db.VarChar(191)
  institution        String?     @db.VarChar(191)
  department         String?     @db.VarChar(191)
  researchGroup      String?     @map("research_group") @db.VarChar(191)
  timezone           String?     @db.VarChar(100)
  countryCode        String      @map("country_code") @db.VarChar(10)
  mobileNumber       String      @map("mobile_number") @db.VarChar(20)
  referralCode       String?     @map("referral_code") @db.VarChar(50)
  passwordHash       String      @map("password_hash") @db.VarChar(255)
  passwordChangedAt  DateTime?   @map("password_changed_at")
  twoFactorEnabled   Boolean     @default(false) @map("two_factor_enabled")
  notificationPreferences Json?  @map("notification_preferences")
  dateOfBirth        DateTime    @map("date_of_birth") @db.Date
  resetToken         String?     @map("reset_token") @db.VarChar(255)
  resetTokenExpires  DateTime?   @map("reset_token_expires")
  lastLoginAt        DateTime?   @map("last_login_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  roles              UserRole[]
  auditLogs          AuditLog[]
  uploadBatches      UploadBatch[] @relation("UploadBatchCreatedBy")
  importJobs         ImportJob[] @relation("ImportJobCreatedBy")
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces    Workspace[] @relation("WorkspaceOwner")
  datasetsCreated    Dataset[] @relation("DatasetCreatedBy")
  analysisJobsCreated AnalysisJob[] @relation("AnalysisJobCreatedBy")
  reportsCreated     Report[] @relation("ReportCreatedBy")
  notifications      Notification[]
  uploadedAssets     FileAsset[] @relation("FileAssetUploadedBy")
  pipelineRunsTriggered PipelineRun[] @relation("PipelineRunTriggeredBy")
  pipelineArtifactsCreated PipelineArtifact[] @relation("PipelineArtifactCreatedBy")
  modelRegistryEntriesCreated ModelRegistryEntry[] @relation("ModelRegistryEntryCreatedBy")

  @@unique([countryCode, mobileNumber])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid()) @db.VarChar(30)
  name        String           @unique @db.VarChar(191)
  description String?          @db.VarChar(255)
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid()) @db.VarChar(30)
  name        String           @unique @db.VarChar(191)
  description String?          @db.VarChar(255)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.VarChar(30)
  roleId String @map("role_id") @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String      @map("role_id") @db.VarChar(30)
  permissionId String      @map("permission_id") @db.VarChar(30)
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Domain {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  subdomains SubDomain[]
  healthData HealthData[]
  @@map("domains")
}

model SubDomain {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  domainId   String       @map("domain_id") @db.VarChar(30)
  domain     Domain       @relation(fields: [domainId], references: [id], onDelete: Restrict)
  categories Category[]
  healthData HealthData[]
  @@index([domainId])
  @@map("subdomains")
}

model Category {
  id            String        @id @default(cuid()) @db.VarChar(30)
  name          String        @unique @db.VarChar(191)
  subDomainId   String        @map("subdomain_id") @db.VarChar(30)
  subDomain     SubDomain     @relation(fields: [subDomainId], references: [id], onDelete: Restrict)
  subcategories SubCategory[]
  healthData    HealthData[]
  @@index([subDomainId])
  @@map("categories")
}

model SubCategory {
  id           String       @id @default(cuid()) @db.VarChar(30)
  name         String       @unique @db.VarChar(191)
  categoryId   String       @map("category_id") @db.VarChar(30)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  healthData   HealthData[]
  @@index([categoryId])
  @@map("subcategories")
}

model HealthOutcome {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("health_outcomes")
}

model Variable {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("variables")
}

model Demographic {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("demographics")
}

model GeographyUnit {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("geography_units")
}

model DataUnit {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_units")
}

model DataSource {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_sources")
}

model DataPortal {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_portals")
}

model DataFormat {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_formats")
}

model DataLocation {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_locations")
}

model UploadBatch {
  id            String          @id @default(cuid()) @db.VarChar(30)
  fileName      String          @map("file_name") @db.VarChar(255)
  originalName  String          @map("original_name") @db.VarChar(255)
  mimeType      String          @map("mime_type") @db.VarChar(100)
  status        ImportJobStatus @default(PENDING)
  createdById   String          @map("created_by_id") @db.VarChar(30)
  createdBy     User            @relation("UploadBatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime        @default(now()) @map("created_at")
  importJobs    ImportJob[]

  @@index([createdById])
  @@map("upload_batches")
}

model ImportJob {
  id             String          @id @default(cuid()) @db.VarChar(30)
  uploadBatchId  String          @map("upload_batch_id") @db.VarChar(30)
  status         ImportJobStatus @default(PENDING)
  startedAt      DateTime?       @map("started_at")
  finishedAt     DateTime?       @map("finished_at")
  errorMessage   String?         @map("error_message") @db.Text
  createdById    String          @map("created_by_id") @db.VarChar(30)
  createdBy      User            @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  uploadBatch    UploadBatch     @relation(fields: [uploadBatchId], references: [id], onDelete: Cascade)
  validationErrors ValidationError[]

  @@index([uploadBatchId])
  @@index([createdById])
  @@map("import_jobs")
}

model ValidationError {
  id          String     @id @default(cuid()) @db.VarChar(30)
  importJobId String     @map("import_job_id") @db.VarChar(30)
  rowNumber   Int?       @map("row_number")
  fieldName   String?    @map("field_name") @db.VarChar(191)
  message     String     @db.Text
  importJob   ImportJob  @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("validation_errors")
}

model HealthData {
  id               String          @id @default(cuid()) @db.VarChar(30)
  title            String          @db.VarChar(255)
  dataYear         Int             @map("data_year")
  value            Decimal?        @db.Decimal(18, 4)
  notes            String?         @db.Text
  processedStatus  ProcessedStatus @default(PENDING) @map("processed_status")
  processedAt      DateTime?       @map("processed_at")
  domainId         String          @map("domain_id") @db.VarChar(30)
  subDomainId      String          @map("subdomain_id") @db.VarChar(30)
  categoryId       String          @map("category_id") @db.VarChar(30)
  subCategoryId    String?         @map("subcategory_id") @db.VarChar(30)
  healthOutcomeId  String          @map("health_outcome_id") @db.VarChar(30)
  variableId       String          @map("variable_id") @db.VarChar(30)
  demographicId    String          @map("demographic_id") @db.VarChar(30)
  geographyUnitId  String          @map("geography_unit_id") @db.VarChar(30)
  dataUnitId       String          @map("data_unit_id") @db.VarChar(30)
  dataSourceId     String          @map("data_source_id") @db.VarChar(30)
  dataPortalId     String?         @map("data_portal_id") @db.VarChar(30)
  dataFormatId     String?         @map("data_format_id") @db.VarChar(30)
  dataLocationId   String?         @map("data_location_id") @db.VarChar(30)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  domain           Domain          @relation(fields: [domainId], references: [id], onDelete: Restrict)
  subDomain        SubDomain       @relation(fields: [subDomainId], references: [id], onDelete: Restrict)
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory      SubCategory?    @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  healthOutcome    HealthOutcome   @relation(fields: [healthOutcomeId], references: [id], onDelete: Restrict)
  variable         Variable        @relation(fields: [variableId], references: [id], onDelete: Restrict)
  demographic      Demographic     @relation(fields: [demographicId], references: [id], onDelete: Restrict)
  geographyUnit    GeographyUnit   @relation(fields: [geographyUnitId], references: [id], onDelete: Restrict)
  dataUnit         DataUnit        @relation(fields: [dataUnitId], references: [id], onDelete: Restrict)
  dataSource       DataSource      @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)
  dataPortal       DataPortal?     @relation(fields: [dataPortalId], references: [id], onDelete: Restrict)
  dataFormat       DataFormat?     @relation(fields: [dataFormatId], references: [id], onDelete: Restrict)
  dataLocation     DataLocation?   @relation(fields: [dataLocationId], references: [id], onDelete: Restrict)

  @@index([dataYear])
  @@index([domainId])
  @@index([subDomainId])
  @@index([categoryId])
  @@index([healthOutcomeId])
  @@index([variableId])
  @@map("health_data")
}

model AuditLog {
  id         String   @id @default(cuid()) @db.VarChar(30)
  userId     String?  @map("user_id") @db.VarChar(30)
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(30)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model Workspace {
  id           String           @id @default(cuid()) @db.VarChar(30)
  name         String           @db.VarChar(120)
  description  String?          @db.Text
  status       WorkspaceStatus  @default(ACTIVE)
  ownerId      String           @db.VarChar(30)
  owner        User             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  datasets     Dataset[]
  analysisJobs AnalysisJob[]
  reports      Report[]
  notifications Notification[]
  pipelineRuns PipelineRun[]
  pipelineArtifacts PipelineArtifact[]
  modelRegistryEntries ModelRegistryEntry[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
}

model WorkspaceMember {
  id          String         @id @default(cuid()) @db.VarChar(30)
  workspaceId String         @db.VarChar(30)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String         @db.VarChar(30)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  joinedAt    DateTime       @default(now())
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
}

model Dataset {
  id           String            @id @default(cuid()) @db.VarChar(30)
  name         String            @db.VarChar(140)
  description  String?           @db.Text
  version      Int               @default(1)
  visibility   DatasetVisibility @default(WORKSPACE)
  storagePath  String?           @db.VarChar(255)
  mimeType     String?           @db.VarChar(100)
  sizeBytes    Int?
  recordCount  Int?
  tags         String[]
  workspaceId  String            @db.VarChar(30)
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById  String            @db.VarChar(30)
  createdBy    User              @relation("DatasetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  analysisJobs AnalysisJob[]
  reports      Report[]          @relation("ReportDatasets")
  fileAssets   FileAsset[]
  pipelineRuns PipelineRun[]
  pipelineArtifacts PipelineArtifact[]
  modelRegistryEntries ModelRegistryEntry[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([workspaceId])
  @@index([createdById])
  @@index([visibility])
  @@index([createdAt])
}

model AnalysisJob {
  id             String            @id @default(cuid()) @db.VarChar(30)
  name           String            @db.VarChar(140)
  description    String?           @db.Text
  status         AnalysisJobStatus @default(QUEUED)
  jobType        String            @db.VarChar(80)
  parametersJson Json?
  resultsJson    Json?
  logsText       String?           @db.Text
  workspaceId    String            @db.VarChar(30)
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  datasetId      String?           @db.VarChar(30)
  dataset        Dataset?          @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  createdById    String            @db.VarChar(30)
  createdBy      User              @relation("AnalysisJobCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([workspaceId])
  @@index([datasetId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model Report {
  id           String       @id @default(cuid()) @db.VarChar(30)
  title        String       @db.VarChar(160)
  description  String?      @db.Text
  status       ReportStatus @default(DRAFT)
  reportType   String       @db.VarChar(80)
  storagePath  String?      @db.VarChar(255)
  publicUrl    String?      @db.VarChar(255)
  metadataJson Json?
  workspaceId  String       @db.VarChar(30)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById  String       @db.VarChar(30)
  createdBy    User         @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  datasets     Dataset[]    @relation("ReportDatasets")
  fileAssets   FileAsset[]
  pipelineArtifacts PipelineArtifact[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id          String               @id @default(cuid()) @db.VarChar(30)
  userId      String               @map("user_id") @db.VarChar(30)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?              @map("workspace_id") @db.VarChar(30)
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String               @db.VarChar(191)
  description String               @db.Text
  severity    NotificationSeverity @default(INFO)
  isRead      Boolean              @default(false) @map("is_read")
  readAt      DateTime?            @map("read_at")
  link        String?              @db.VarChar(255)
  createdAt   DateTime             @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([workspaceId])
  @@index([createdAt])
  @@map("notifications")
}

model FileAsset {
  id           String    @id @default(cuid()) @db.VarChar(30)
  fileName     String    @map("file_name") @db.VarChar(255)
  originalName String    @map("original_name") @db.VarChar(255)
  mimeType     String    @map("mime_type") @db.VarChar(100)
  sizeBytes    Int       @map("size_bytes")
  storagePath  String    @map("storage_path") @db.VarChar(255)
  publicUrl    String?   @map("public_url") @db.VarChar(255)
  uploadedById String    @map("uploaded_by_id") @db.VarChar(30)
  uploadedBy   User      @relation("FileAssetUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  datasetId    String?   @map("dataset_id") @db.VarChar(30)
  dataset      Dataset?  @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  reportId     String?   @map("report_id") @db.VarChar(30)
  report       Report?   @relation(fields: [reportId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([datasetId])
  @@index([reportId])
  @@index([uploadedById])
  @@map("file_assets")
}

model PipelineTemplate {
  id             String      @id @default(cuid()) @db.VarChar(30)
  name           String      @db.VarChar(191)
  code           String      @unique @db.VarChar(120)
  description    String?     @db.Text
  isActive       Boolean     @default(true)
  version        Int         @default(1)
  definitionJson Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  runs           PipelineRun[]
}

model PipelineRun {
  id               String            @id @default(cuid()) @db.VarChar(30)
  workspaceId      String            @db.VarChar(30)
  datasetId        String?           @db.VarChar(30)
  requestId        String?           @db.VarChar(30)
  triggeredById    String            @db.VarChar(30)
  templateId       String?           @db.VarChar(30)
  name             String            @db.VarChar(191)
  status           PipelineRunStatus @default(DRAFT)
  currentStepIndex Int               @default(0)
  progressPercent  Float             @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  canceledAt       DateTime?
  failureReason    String?           @db.Text
  parametersJson   Json?
  contextJson      Json?
  metricsJson      Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset          Dataset?          @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  triggeredBy      User              @relation("PipelineRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: Restrict)
  template         PipelineTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  steps            PipelineStep[]
  jobs             WorkerJob[]
  artifacts        PipelineArtifact[]
  events           PipelineEvent[]
  modelRegistryEntries ModelRegistryEntry[]

  @@index([workspaceId, status])
  @@index([datasetId])
  @@index([requestId])
  @@index([triggeredById])
}

model PipelineStep {
  id              String             @id @default(cuid()) @db.VarChar(30)
  pipelineRunId   String             @db.VarChar(30)
  order           Int
  name            String             @db.VarChar(191)
  type            PipelineStepType
  status          PipelineStepStatus @default(PENDING)
  progressPercent Float              @default(0)
  workerType      String?            @db.VarChar(120)
  dependsOnStepId String?            @db.VarChar(30)
  startedAt       DateTime?
  completedAt     DateTime?
  failureReason   String?            @db.Text
  inputJson       Json?
  outputJson      Json?
  configJson      Json?
  metricsJson     Json?
  retryCount      Int                @default(0)
  maxRetries      Int                @default(2)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  pipelineRun     PipelineRun        @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  jobs            WorkerJob[]

  @@unique([pipelineRunId, order])
  @@index([pipelineRunId, status])
}

model WorkerJob {
  id              String          @id @default(cuid()) @db.VarChar(30)
  pipelineRunId   String          @db.VarChar(30)
  pipelineStepId  String?         @db.VarChar(30)
  queueName       String          @db.VarChar(120)
  jobName         String          @db.VarChar(191)
  workerType      String          @db.VarChar(120)
  status          WorkerJobStatus @default(QUEUED)
  brokerJobId     String?         @db.VarChar(120)
  attempt         Int             @default(0)
  progressPercent Float           @default(0)
  payloadJson     Json
  resultJson      Json?
  errorJson       Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  pipelineRun     PipelineRun     @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  pipelineStep    PipelineStep?   @relation(fields: [pipelineStepId], references: [id], onDelete: SetNull)

  @@index([pipelineRunId, status])
  @@index([pipelineStepId])
  @@index([brokerJobId])
}

model PipelineArtifact {
  id              String       @id @default(cuid()) @db.VarChar(30)
  pipelineRunId   String       @db.VarChar(30)
  workspaceId     String       @db.VarChar(30)
  datasetId       String?      @db.VarChar(30)
  reportId        String?      @db.VarChar(30)
  kind            ArtifactKind
  name            String       @db.VarChar(191)
  storageKey      String       @db.VarChar(255)
  mimeType        String?      @db.VarChar(120)
  sizeBytes       BigInt?
  checksum        String?      @db.VarChar(191)
  metadataJson    Json?
  createdById     String?      @db.VarChar(30)
  createdAt       DateTime     @default(now())

  pipelineRun     PipelineRun  @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset         Dataset?     @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  report          Report?      @relation(fields: [reportId], references: [id], onDelete: SetNull)
  createdBy       User?        @relation("PipelineArtifactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([pipelineRunId, kind])
  @@index([workspaceId, kind])
}

model PipelineEvent {
  id              String      @id @default(cuid()) @db.VarChar(30)
  pipelineRunId   String      @db.VarChar(30)
  stepOrder       Int?
  eventType       String      @db.VarChar(120)
  level           String      @db.VarChar(50)
  message         String      @db.Text
  dataJson        Json?
  createdAt       DateTime    @default(now())

  pipelineRun     PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  @@index([pipelineRunId, createdAt])
}

model ModelRegistryEntry {
  id              String       @id @default(cuid()) @db.VarChar(30)
  workspaceId     String       @db.VarChar(30)
  pipelineRunId   String?      @db.VarChar(30)
  datasetId       String?      @db.VarChar(30)
  name            String       @db.VarChar(191)
  version         String       @db.VarChar(120)
  framework       String?      @db.VarChar(120)
  taskType        String?      @db.VarChar(120)
  storageKey      String       @db.VarChar(255)
  metricsJson     Json?
  paramsJson      Json?
  schemaJson      Json?
  isActive        Boolean      @default(true)
  promotedAt      DateTime?
  createdById     String?      @db.VarChar(30)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipelineRun     PipelineRun? @relation(fields: [pipelineRunId], references: [id], onDelete: SetNull)
  dataset         Dataset?     @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  createdBy       User?        @relation("ModelRegistryEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workspaceId, name])
  @@index([datasetId])
}
