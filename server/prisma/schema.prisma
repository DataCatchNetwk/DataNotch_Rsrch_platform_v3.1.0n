generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ProcessedStatus {
  PENDING
  PROCESSED
  FAILED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  RESEARCHER
  VIEWER
}

enum WorkspaceStatus {
  ACTIVE
  ARCHIVED
}

enum DatasetVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
  RESTRICTED
}

enum DatasetDomain {
  HEALTH
  SOCIAL
  CLIMATE
  EDUCATION
  ECONOMIC
  DEMOGRAPHIC
  ENVIRONMENT
  MOBILITY
  GENOMICS
  IMAGING
  WEARABLE
  SURVEY
  OTHER
}

enum DatasetAccessLevel {
  OPEN
  INTERNAL
  RESTRICTED
  APPROVAL_REQUIRED
}

enum DatasetDepositStatus {
  DRAFT
  AVAILABLE
  ARCHIVED
}

enum DatasetAccessAction {
  VIEW_DETAILS
  PREVIEW
  FAVORITED
  UNFAVORITED
  PULL_REQUESTED
}

enum DatasetPullStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ReportStatus {
  DRAFT
  READY
  ARCHIVED
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_REVIEWED
  REQUEST_COMMENT
  DATASET_ADDED
  REPORT_CREATED
  MEMBER_ADDED
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  APPLICATION_NEEDS_MORE_INFO
}

enum AccountStatus {
  PENDING_APPROVAL
  APPROVED_2FA_PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ResearcherType {
  GENERAL_RESEARCHER
  STUDENT_RESEARCHER
  CLINICAL_RESEARCHER
  EXTERNAL_COLLABORATOR
}

enum ApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalDecisionReasonType {
  APPROVED
  REJECTED
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
}

enum PipelineRunStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  PARTIAL_SUCCESS
}

enum PipelineStepStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
  CANCELED
}

enum PipelineStepType {
  INGEST
  PROFILE
  VALIDATE
  CLEAN
  TRANSFORM
  FEATURE_ENGINEERING
  SPLIT
  TRAIN
  EVALUATE
  EXPLAIN
  CHART
  REPORT
  EXPORT
  PUBLISH
}

enum WorkerJobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  RETRYING
  CANCELED
}

enum ArtifactKind {
  DATASET
  CLEANED_DATASET
  FEATURE_SET
  MODEL
  METRICS
  CHART
  REPORT
  EXPORT_PACKAGE
  LOG
}

enum SupportTicketStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
  SPAM
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportTicketCategory {
  LOGIN
  BILLING
  TECHNICAL
  DATASET
  ACCESS
  ACCOUNT
  SECURITY
  OTHER
}

enum SupportTicketSource {
  LOGIN_PAGE
  USER_DASHBOARD
  ADMIN_CREATED
  EMAIL_INGEST
  API
}

enum SupportMessageAuthorType {
  USER
  ADMIN
  AI
  SYSTEM
}

// Research Platform Enums
enum ResearchDomain {
  HEALTH
  SOCIAL_SCIENCE
  CLIMATE
  GENOMICS
  PUBLIC_HEALTH
  IMAGING
  WEARABLES
  SURVEY
  OTHER
}

enum WorkspaceSnapshotStatus {
  DRAFT
  FROZEN
  ARCHIVED
}

enum AnalysisRunType {
  DESCRIPTIVE
  REGRESSION
  CLASSIFICATION
  SURVIVAL
  CLUSTERING
  DIM_REDUCTION
  GENOMICS
  CUSTOM
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum AnalysisAlgorithmType {
  // ── Tree-based ───────────────────────────────────────────────────────────
  DECISION_TREE
  RANDOM_FOREST
  GRADIENT_BOOSTING
  XGBOOST
  LIGHTGBM
  CATBOOST
  EXTRA_TREES
  ADABOOST
  BAGGING

  // ── Neural Networks ──────────────────────────────────────────────────────
  ANN_MLP
  CNN
  RNN
  LSTM
  GRU
  TRANSFORMER
  AUTOENCODER

  // ── Bayesian ─────────────────────────────────────────────────────────────
  NAIVE_BAYES
  BAYESIAN_NETWORK
  GAUSSIAN_PROCESS

  // ── Statistical / Linear ─────────────────────────────────────────────────
  LINEAR_REGRESSION
  LOGISTIC_REGRESSION
  RIDGE
  LASSO
  ELASTIC_NET
  ANOVA
  LINEAR_MIXED_MODELS
  POLYNOMIAL_REGRESSION

  // ── Support Vector ───────────────────────────────────────────────────────
  SVM
  SVR

  // ── Nearest Neighbour ────────────────────────────────────────────────────
  KNN

  // ── Clustering / Unsupervised ────────────────────────────────────────────
  K_MEANS
  DBSCAN
  HIERARCHICAL_CLUSTERING
  GAUSSIAN_MIXTURE
  MEAN_SHIFT
  SPECTRAL_CLUSTERING

  // ── Survival ─────────────────────────────────────────────────────────────
  KAPLAN_MEIER
  COX_PH
  COMPETING_RISKS
  RANDOM_SURVIVAL_FOREST
  WEIBULL_AFT

  // ── Dimensionality Reduction ─────────────────────────────────────────────
  PCA
  UMAP
  TSNE
  NMF
  ICA
  FACTOR_ANALYSIS

  // ── Custom ───────────────────────────────────────────────────────────────
  CUSTOM
}

model User {
  id                 String      @id @default(cuid()) @db.VarChar(30)
  firstname          String      @db.VarChar(100)
  surname            String      @db.VarChar(100)
  email              String      @unique @db.VarChar(191)
  institution        String?     @db.VarChar(191)
  department         String?     @db.VarChar(191)
  researchGroup      String?     @map("research_group") @db.VarChar(191)
  timezone           String?     @db.VarChar(100)
  countryCode        String      @map("country_code") @db.VarChar(10)
  mobileNumber       String      @map("mobile_number") @db.VarChar(20)
  referralCode       String?     @map("referral_code") @db.VarChar(50)
  passwordHash       String      @map("password_hash") @db.VarChar(255)
  passwordChangedAt  DateTime?   @map("password_changed_at")
  twoFactorEnabled   Boolean     @default(false) @map("two_factor_enabled")
  notificationPreferences Json?  @map("notification_preferences")
  dateOfBirth        DateTime    @map("date_of_birth") @db.Date
  resetToken         String?       @map("reset_token") @db.VarChar(255)
  resetTokenExpires  DateTime?     @map("reset_token_expires")
  lastLoginAt        DateTime?     @map("last_login_at")
  accountStatus      AccountStatus @default(PENDING_APPROVAL) @map("account_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  roles              UserRole[]
  application        ResearcherApplication?
  accessRequestsRequested AccessRequest[] @relation("AccessRequestRequester")
  accessRequestsReviewed  AccessRequest[] @relation("AccessRequestReviewer")
  adminAuditEventsAuthored AdminAuditEvent[] @relation("AdminAuditActor")
  approvalDecisionReasonsAuthored ApprovalDecisionReason[] @relation("ApprovalDecisionActor")
  auditLogs          AuditLog[]
  uploadBatches      UploadBatch[] @relation("UploadBatchCreatedBy")
  importJobs         ImportJob[] @relation("ImportJobCreatedBy")
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces    Workspace[] @relation("WorkspaceOwner")
  datasetsCreated    Dataset[] @relation("DatasetCreatedBy")
  analysisJobsCreated AnalysisJob[] @relation("AnalysisJobCreatedBy")
  reportsCreated     Report[] @relation("ReportCreatedBy")
  notifications      Notification[]
  uploadedAssets     FileAsset[] @relation("FileAssetUploadedBy")
  pipelineRunsTriggered PipelineRun[] @relation("PipelineRunTriggeredBy")
  pipelineArtifactsCreated PipelineArtifact[] @relation("PipelineArtifactCreatedBy")
  modelRegistryEntriesCreated ModelRegistryEntry[] @relation("ModelRegistryEntryCreatedBy")
  assignedSupportTickets  SupportTicket[] @relation("AssignedSupportTickets")
  createdSupportTickets   SupportTicket[] @relation("CreatedSupportTickets")
  supportMessages         SupportMessage[]
  supportActivities       SupportActivity[]
  datasetFavorites        DatasetFavorite[]
  datasetPullRequests     DatasetPullRequest[]
  datasetAccessLogs       DatasetAccessLog[]
  cohortDefinitions       CohortDefinition[] @relation("CohortDefinitionCreatedBy")
  featureSets             FeatureSet[] @relation("FeatureSetCreatedBy")
  ownedResearchWorkspaces ResearchWorkspace[] @relation("ResearchWorkspaceOwner")

  @@unique([countryCode, mobileNumber])
  @@map("users")
}

model SupportTicket {
  id                String                 @id @default(cuid()) @db.VarChar(30)
  ticketNumber      String                 @unique @map("ticket_number") @db.VarChar(50)
  subject           String                 @db.VarChar(255)
  description       String                 @db.Text
  requesterEmail    String                 @map("requester_email") @db.VarChar(191)
  requesterName     String?                @map("requester_name") @db.VarChar(191)
  category          SupportTicketCategory
  status            SupportTicketStatus    @default(OPEN)
  priority          SupportTicketPriority  @default(MEDIUM)
  source            SupportTicketSource    @default(LOGIN_PAGE)
  tags              String[]
  sentimentScore    Float?                 @map("sentiment_score")
  spamScore         Float?                 @map("spam_score")
  urgencyScore      Float?                 @map("urgency_score")
  aiSummary         String?                @map("ai_summary") @db.Text
  aiSuggestedReply  String?                @map("ai_suggested_reply") @db.Text
  aiTriageReason    String?                @map("ai_triage_reason") @db.Text
  aiLastAnalyzedAt  DateTime?              @map("ai_last_analyzed_at")
  attachmentUrl     String?                @map("attachment_url") @db.VarChar(500)
  attachmentName    String?                @map("attachment_name") @db.VarChar(255)
  assignedToId      String?                @map("assigned_to_id") @db.VarChar(30)
  assignedTo        User?                  @relation("AssignedSupportTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdByUserId   String?                @map("created_by_user_id") @db.VarChar(30)
  createdByUser     User?                  @relation("CreatedSupportTickets", fields: [createdByUserId], references: [id], onDelete: SetNull)
  firstResponseAt   DateTime?              @map("first_response_at")
  resolvedAt        DateTime?              @map("resolved_at")
  closedAt          DateTime?              @map("closed_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  messages          SupportMessage[]
  activities        SupportActivity[]

  @@index([status, priority, createdAt])
  @@index([assignedToId, status])
  @@index([requesterEmail])
  @@map("support_tickets")
}

model SupportMessage {
  id              String                   @id @default(cuid()) @db.VarChar(30)
  ticketId        String                   @map("ticket_id") @db.VarChar(30)
  ticket          SupportTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorType      SupportMessageAuthorType @map("author_type")
  authorUserId    String?                  @map("author_user_id") @db.VarChar(30)
  authorUser      User?                    @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  body            String                   @db.Text
  isInternal      Boolean                  @default(false) @map("is_internal")
  attachmentUrl   String?                  @map("attachment_url") @db.VarChar(500)
  attachmentName  String?                  @map("attachment_name") @db.VarChar(255)
  createdAt       DateTime                 @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_messages")
}

model SupportActivity {
  id            String         @id @default(cuid()) @db.VarChar(30)
  ticketId      String         @map("ticket_id") @db.VarChar(30)
  ticket        SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUserId   String?        @map("actor_user_id") @db.VarChar(30)
  actorUser     User?          @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  type          String         @db.VarChar(100)
  description   String         @db.Text
  metaJson      Json?          @map("meta_json")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_activities")
}

model Role {
  id          String           @id @default(cuid()) @db.VarChar(30)
  name        String           @unique @db.VarChar(191)
  description String?          @db.VarChar(255)
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid()) @db.VarChar(30)
  name        String           @unique @db.VarChar(191)
  description String?          @db.VarChar(255)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.VarChar(30)
  roleId String @map("role_id") @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String      @map("role_id") @db.VarChar(30)
  permissionId String      @map("permission_id") @db.VarChar(30)
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Domain {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  subdomains SubDomain[]
  healthData HealthData[]
  @@map("domains")
}

model SubDomain {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  domainId   String       @map("domain_id") @db.VarChar(30)
  domain     Domain       @relation(fields: [domainId], references: [id], onDelete: Restrict)
  categories Category[]
  healthData HealthData[]
  @@index([domainId])
  @@map("subdomains")
}

model Category {
  id            String        @id @default(cuid()) @db.VarChar(30)
  name          String        @unique @db.VarChar(191)
  subDomainId   String        @map("subdomain_id") @db.VarChar(30)
  subDomain     SubDomain     @relation(fields: [subDomainId], references: [id], onDelete: Restrict)
  subcategories SubCategory[]
  healthData    HealthData[]
  @@index([subDomainId])
  @@map("categories")
}

model SubCategory {
  id           String       @id @default(cuid()) @db.VarChar(30)
  name         String       @unique @db.VarChar(191)
  categoryId   String       @map("category_id") @db.VarChar(30)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  healthData   HealthData[]
  @@index([categoryId])
  @@map("subcategories")
}

model HealthOutcome {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("health_outcomes")
}

model Variable {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("variables")
}

model Demographic {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("demographics")
}

model GeographyUnit {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("geography_units")
}

model DataUnit {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_units")
}

model DataSource {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_sources")
}

model DataPortal {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_portals")
}

model DataFormat {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_formats")
}

model DataLocation {
  id         String       @id @default(cuid()) @db.VarChar(30)
  name       String       @unique @db.VarChar(191)
  healthData HealthData[]
  @@map("data_locations")
}

model UploadBatch {
  id            String          @id @default(cuid()) @db.VarChar(30)
  fileName      String          @map("file_name") @db.VarChar(255)
  originalName  String          @map("original_name") @db.VarChar(255)
  mimeType      String          @map("mime_type") @db.VarChar(100)
  status        ImportJobStatus @default(PENDING)
  createdById   String          @map("created_by_id") @db.VarChar(30)
  createdBy     User            @relation("UploadBatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime        @default(now()) @map("created_at")
  importJobs    ImportJob[]

  @@index([createdById])
  @@map("upload_batches")
}

model ImportJob {
  id             String          @id @default(cuid()) @db.VarChar(30)
  uploadBatchId  String          @map("upload_batch_id") @db.VarChar(30)
  status         ImportJobStatus @default(PENDING)
  startedAt      DateTime?       @map("started_at")
  finishedAt     DateTime?       @map("finished_at")
  errorMessage   String?         @map("error_message") @db.Text
  createdById    String          @map("created_by_id") @db.VarChar(30)
  createdBy      User            @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  uploadBatch    UploadBatch     @relation(fields: [uploadBatchId], references: [id], onDelete: Cascade)
  validationErrors ValidationError[]

  @@index([uploadBatchId])
  @@index([createdById])
  @@map("import_jobs")
}

model ValidationError {
  id          String     @id @default(cuid()) @db.VarChar(30)
  importJobId String     @map("import_job_id") @db.VarChar(30)
  rowNumber   Int?       @map("row_number")
  fieldName   String?    @map("field_name") @db.VarChar(191)
  message     String     @db.Text
  importJob   ImportJob  @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("validation_errors")
}

model HealthData {
  id               String          @id @default(cuid()) @db.VarChar(30)
  title            String          @db.VarChar(255)
  dataYear         Int             @map("data_year")
  value            Decimal?        @db.Decimal(18, 4)
  notes            String?         @db.Text
  processedStatus  ProcessedStatus @default(PENDING) @map("processed_status")
  processedAt      DateTime?       @map("processed_at")
  domainId         String          @map("domain_id") @db.VarChar(30)
  subDomainId      String          @map("subdomain_id") @db.VarChar(30)
  categoryId       String          @map("category_id") @db.VarChar(30)
  subCategoryId    String?         @map("subcategory_id") @db.VarChar(30)
  healthOutcomeId  String          @map("health_outcome_id") @db.VarChar(30)
  variableId       String          @map("variable_id") @db.VarChar(30)
  demographicId    String          @map("demographic_id") @db.VarChar(30)
  geographyUnitId  String          @map("geography_unit_id") @db.VarChar(30)
  dataUnitId       String          @map("data_unit_id") @db.VarChar(30)
  dataSourceId     String          @map("data_source_id") @db.VarChar(30)
  dataPortalId     String?         @map("data_portal_id") @db.VarChar(30)
  dataFormatId     String?         @map("data_format_id") @db.VarChar(30)
  dataLocationId   String?         @map("data_location_id") @db.VarChar(30)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  domain           Domain          @relation(fields: [domainId], references: [id], onDelete: Restrict)
  subDomain        SubDomain       @relation(fields: [subDomainId], references: [id], onDelete: Restrict)
  category         Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory      SubCategory?    @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  healthOutcome    HealthOutcome   @relation(fields: [healthOutcomeId], references: [id], onDelete: Restrict)
  variable         Variable        @relation(fields: [variableId], references: [id], onDelete: Restrict)
  demographic      Demographic     @relation(fields: [demographicId], references: [id], onDelete: Restrict)
  geographyUnit    GeographyUnit   @relation(fields: [geographyUnitId], references: [id], onDelete: Restrict)
  dataUnit         DataUnit        @relation(fields: [dataUnitId], references: [id], onDelete: Restrict)
  dataSource       DataSource      @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)
  dataPortal       DataPortal?     @relation(fields: [dataPortalId], references: [id], onDelete: Restrict)
  dataFormat       DataFormat?     @relation(fields: [dataFormatId], references: [id], onDelete: Restrict)
  dataLocation     DataLocation?   @relation(fields: [dataLocationId], references: [id], onDelete: Restrict)

  @@index([dataYear])
  @@index([domainId])
  @@index([subDomainId])
  @@index([categoryId])
  @@index([healthOutcomeId])
  @@index([variableId])
  @@map("health_data")
}

model AuditLog {
  id         String   @id @default(cuid()) @db.VarChar(30)
  userId     String?  @map("user_id") @db.VarChar(30)
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(30)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model Workspace {
  id           String           @id @default(cuid()) @db.VarChar(30)
  name         String           @db.VarChar(120)
  description  String?          @db.Text
  status       WorkspaceStatus  @default(ACTIVE)
  ownerId      String           @db.VarChar(30)
  owner        User             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  datasets     Dataset[]
  analysisJobs AnalysisJob[]
  reports      Report[]
  notifications Notification[]
  pipelineRuns PipelineRun[]
  pipelineArtifacts PipelineArtifact[]
  modelRegistryEntries ModelRegistryEntry[]
  datasetPullRequests DatasetPullRequest[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
}

model WorkspaceMember {
  id          String         @id @default(cuid()) @db.VarChar(30)
  workspaceId String         @db.VarChar(30)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String         @db.VarChar(30)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  joinedAt    DateTime       @default(now())
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
}

model Dataset {
  id           String            @id @default(cuid()) @db.VarChar(30)
  name         String            @db.VarChar(140)
  description  String?           @db.Text
  version      Int               @default(1)
  visibility   DatasetVisibility @default(WORKSPACE)
  storagePath  String?           @db.VarChar(255)
