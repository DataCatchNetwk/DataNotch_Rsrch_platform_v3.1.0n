# ─── Cloud E2E Test Configuration ────────────────────────────────────────────
# Copy this file to .env.e2e and fill in the values.
# .env.e2e is gitignored — never commit real credentials.

# ── Deployment URLs ───────────────────────────────────────────────────────────
# Override the defaults if your deployment URLs differ.
# Defaults (already hardcoded in playwright.cloud.config.ts):
#   E2E_FRONTEND_URL=https://data-notch-rsrch-platform-v3-1-0n-w.vercel.app
#   E2E_BACKEND_URL=https://datacatchnetwk.onrender.com

# E2E_FRONTEND_URL=https://data-notch-rsrch-platform-v3-1-0n-w.vercel.app
# E2E_BACKEND_URL=https://datacatchnetwk.onrender.com

# ── Admin credentials (optional — enables DB verification in test 4) ──────────
# Set E2E_ADMIN_TOKEN to a valid admin JWT obtained from the deployed backend.
# Without this, test 4 (Supabase DB verification) is automatically skipped.
#
# How to get a token:
#   curl -s -X POST https://datacatchnetwk.onrender.com/api/v1/auth/login \
#     -H "Content-Type: application/json" \
#     -d '{"identifier":"<admin-email>","password":"<admin-password>"}' \
#     | jq -r '.token'
#
# E2E_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
