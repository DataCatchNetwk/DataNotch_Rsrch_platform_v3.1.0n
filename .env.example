# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000
SERVER_PUBLIC_URL=http://localhost:3001

# Auth
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
AUTH_NETWORK_BLOCK_ENABLED=true
AUTH_NETWORK_FAIL_CLOSED=false
AUTH_NETWORK_CHECK_URL=https://api.ipapi.is
AUTH_NETWORK_CHECK_TIMEOUT_MS=6000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=health_data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/health_data?schema=public

# Runtime protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=40

# Queue backend
QUEUE_BACKEND=postgres
POSTGRES_WORKER_POLL_MS=1500

# Redis / BullMQ (optional production backend only when QUEUE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379
PIPELINE_EVENT_STREAM_KEY=pipeline:events
AUTOSCALE_TARGET_JOBS_PER_REPLICA=8
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=24

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
