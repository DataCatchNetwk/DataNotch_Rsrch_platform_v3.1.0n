# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000
SERVER_PUBLIC_URL=http://localhost:3001

# Auth
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/google/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/microsoft/callback
AUTH_NETWORK_BLOCK_ENABLED=true
AUTH_NETWORK_FAIL_CLOSED=false
AUTH_NETWORK_CHECK_URL=https://api.ipapi.is
AUTH_NETWORK_CHECK_TIMEOUT_MS=6000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_HOST=HOST
DATABASE_PORT=5432
DATABASE_USER=USER
DATABASE_PASSWORD=PASSWORD
DATABASE_NAME=DATABASE

# Runtime protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=40

# Queue backend
QUEUE_BACKEND=postgres
POSTGRES_WORKER_POLL_MS=1500

# Redis / BullMQ (optional production backend only when QUEUE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379
PIPELINE_EVENT_STREAM_KEY=pipeline:events
AUTOSCALE_TARGET_JOBS_PER_REPLICA=8
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=24

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
