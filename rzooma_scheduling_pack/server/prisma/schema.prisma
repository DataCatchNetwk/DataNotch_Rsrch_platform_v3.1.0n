generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum Role { ADMIN USER RESEARCHER }
enum EventType { MEETING DEADLINE REVIEW SYNC WORKSHOP CALL }
enum EventStatus { SCHEDULED LIVE PAUSED COMPLETED CANCELLED }
enum ResponseStatus { PENDING ACCEPTED DECLINED TENTATIVE }

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(USER)
  avatarUrl String?
  eventsCreated RZoomaEvent[] @relation("CreatedEvents")
  invitations RZoomaParticipant[]
}

model ResearchAsset {
  id      String @id @default(cuid())
  type    String
  title   String
  version String?
  events  RZoomaEvent[]
}

model RZoomaEvent {
  id          String @id @default(cuid())
  title       String
  subtitle    String?
  description String?
  type        EventType @default(MEETING)
  status      EventStatus @default(SCHEDULED)
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean @default(false)
  location    String?
  color       String @default("violet")
  rzoomaRoomUrl String?
  createdById String
  createdBy   User @relation("CreatedEvents", fields: [createdById], references: [id])
  assetId     String?
  asset       ResearchAsset? @relation(fields: [assetId], references: [id])
  participants RZoomaParticipant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RZoomaParticipant {
  id      String @id @default(cuid())
  eventId String
  userId  String
  response ResponseStatus @default(PENDING)
  event   RZoomaEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([eventId, userId])
}
