# Server
NODE_ENV=development
PORT=3001
PORT_FALLBACK_ENABLED=true
CLIENT_URL=http://localhost:3000
SERVER_PUBLIC_URL=http://localhost:3001

# Auth
JWT_SECRET=replace-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/google/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/microsoft/callback
AUTH_NETWORK_BLOCK_ENABLED=true
AUTH_NETWORK_FAIL_CLOSED=false
AUTH_NETWORK_CHECK_URL=https://api.ipapi.is
AUTH_NETWORK_CHECK_TIMEOUT_MS=6000

# SMTP email notifications (researcher application status updates)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-app-password
SMTP_FROM="DataNotch Research Platform <no-reply@example.com>"
SMTP_SECURE=false

# Database
# Supabase direct connection:
# DATABASE_URL="postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Supabase pooler connection, if you choose the pooler from the Supabase dashboard:
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@YOUR_POOLER_HOST:6543/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:YOUR_DATABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Runtime protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=40

# Queue backend
QUEUE_BACKEND=postgres
POSTGRES_WORKER_POLL_MS=1500

# Redis / BullMQ (optional production backend only when QUEUE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379
PIPELINE_EVENT_STREAM_KEY=pipeline:events
AUTOSCALE_TARGET_JOBS_PER_REPLICA=8
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=24
