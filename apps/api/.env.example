# Server
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000
SERVER_PUBLIC_URL=http://localhost:3001

# CORS Configuration (comma-separated list of allowed origins)
CLIENT_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
AUTH_NETWORK_BLOCK_ENABLED=true
AUTH_NETWORK_FAIL_CLOSED=false
AUTH_NETWORK_CHECK_URL=https://api.ipapi.is
AUTH_NETWORK_CHECK_TIMEOUT_MS=6000

# Database
# Supabase direct connection (port 5432) — recommended for Render:
# DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?sslmode=require"
#
# Supabase pooler connection (port 6543) — if you use the Supabase pgBouncer pooler:
# DATABASE_URL="postgresql://<USER>:<PASSWORD>@<POOLER_HOST>:6543/<DATABASE>?sslmode=require"
# When using the pooler URL above, also set DIRECT_URL to the port-5432 direct URL:
# DIRECT_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?sslmode=require"
#
# If DATABASE_URL is already a direct connection, DIRECT_URL can be omitted
# (the backend will automatically fall back to DATABASE_URL).
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?sslmode=require"
# DIRECT_URL="postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?sslmode=require"

# Runtime protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=40

# Queue backend
QUEUE_BACKEND=postgres
POSTGRES_WORKER_POLL_MS=1500

# Redis / BullMQ (optional production backend only when QUEUE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379
PIPELINE_EVENT_STREAM_KEY=pipeline:events
AUTOSCALE_TARGET_JOBS_PER_REPLICA=8
AUTOSCALE_MIN_REPLICAS=1
AUTOSCALE_MAX_REPLICAS=24

# Storage Configuration
# Development: local filesystem
# Production: Supabase Storage
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=supabase

# Supabase Storage (required when STORAGE_PROVIDER=supabase)
# SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
# SUPABASE_STORAGE_BUCKET=research-platform-storage
