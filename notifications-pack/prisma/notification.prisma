enum NotificationCategory {
  SYSTEM
  DATASET
  WORKSPACE
  COLLABORATION
  REVIEW
  REQUEST
  ANALYSIS
  REPORT
  BILLING
  SECURITY
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model Notification {
  id            String                @id @default(cuid())
  userId        String
  actorId       String?
  title         String
  message       String
  category      NotificationCategory  @default(SYSTEM)
  priority      NotificationPriority  @default(NORMAL)
  status        NotificationStatus    @default(UNREAD)
  actionLabel   String?
  actionUrl     String?
  entityType    String?
  entityId      String?
  icon          String?
  metadata      Json?
  readAt        DateTime?
  archivedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  user          User                  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor         User?                 @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  deliveries    NotificationDelivery[]

  @@index([userId, status, createdAt])
  @@index([userId, category, createdAt])
  @@index([entityType, entityId])
}

model NotificationDelivery {
  id              String               @id @default(cuid())
  notificationId  String
  channel         NotificationChannel  @default(IN_APP)
  deliveredAt     DateTime?
  failedAt        DateTime?
  errorMessage    String?
  createdAt       DateTime             @default(now())

  notification    Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId, channel])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(true)
  pushEnabled           Boolean  @default(true)
  inAppEnabled          Boolean  @default(true)
  datasetAlerts         Boolean  @default(true)
  workspaceAlerts       Boolean  @default(true)
  collaborationAlerts   Boolean  @default(true)
  reviewAlerts          Boolean  @default(true)
  analysisAlerts        Boolean  @default(true)
  reportAlerts          Boolean  @default(true)
  billingAlerts         Boolean  @default(true)
  securityAlerts        Boolean  @default(true)
  quietHoursStart       String?
  quietHoursEnd         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

