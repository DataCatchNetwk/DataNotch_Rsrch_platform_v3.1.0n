generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  REVIEWER
}

enum AccountStatus {
  PENDING_APPROVAL
  APPROVED_2FA_PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum DatasetVisibility {
  PRIVATE
  TEAM
  PUBLIC
  RESTRICTED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum StorageProvider {
  S3
  MINIO
  LOCAL
}

enum DatasetFileKind {
  ORIGINAL
  CHUNK
  MERGED
  CLEANED
  PREVIEW
  PROFILE
  REPORT
  CHART
  EXPORT
  ATTACHMENT
}

enum UploadStatus {
  INITIATED
  UPLOADING
  COMPLETED
  FAILED
  ABORTED
}

enum ArtifactKind {
  PDF_REPORT
  CSV_EXPORT
  XLSX_EXPORT
  JSON_EXPORT
  PNG_CHART
  ZIP_BUNDLE
  PREVIEW_JSON
  PROFILE_JSON
}

enum PipelineStage {
  UPLOAD
  MERGE
  READ
  PROFILE
  CLEAN
  ANALYZE
  REPORT
  EXPORT
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String?
  fullName      String
  role          UserRole        @default(USER)
  status        AccountStatus   @default(PENDING_APPROVAL)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ownedWorkspaces Workspace[]   @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  datasets         Dataset[]
  uploads          MultipartUpload[] @relation("UploadInitiatedBy")
  createdFiles     DatasetFile[] @relation("DatasetFileCreatedBy")
  createdArtifacts Artifact[]   @relation("ArtifactCreatedBy")
  jobs             AnalysisJob[] @relation("AnalysisJobCreatedBy")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  datasets    Dataset[]
}

model WorkspaceMember {
  id          String            @id @default(cuid())
  workspaceId String
  userId      String
  role        String
  createdAt   DateTime          @default(now())

  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model ObjectStorageConfig {
  id             String          @id @default(cuid())
  provider       StorageProvider
  bucket         String
  region         String?
  endpoint       String?
  accessKeyId    String
  secretKeyEnc   String
  forcePathStyle Boolean         @default(false)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Dataset {
  id               String              @id @default(cuid())
  workspaceId      String
  ownerId          String
  name             String
  description      String?
  visibility       DatasetVisibility   @default(PRIVATE)
  status           JobStatus           @default(QUEUED)
  originalFilename String?
  mimeType         String?
  sizeBytes        BigInt?
  rowCount         Int?
  columnCount      Int?
  schemaJson       Json?
  profileJson      Json?
  tags             String[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner            User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files            DatasetFile[]
  uploads          MultipartUpload[]
  artifacts        Artifact[]
  jobs             AnalysisJob[]
}

model DatasetFile {
  id               String              @id @default(cuid())
  datasetId        String
  kind             DatasetFileKind
  storageKey       String
  bucket           String
  originalFilename String?
  mimeType         String?
  extension        String?
  checksumSha256   String?
  sizeBytes        BigInt
  metadataJson     Json?
  createdById      String?
  createdAt        DateTime            @default(now())

  dataset          Dataset             @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  createdBy        User?               @relation("DatasetFileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model MultipartUpload {
  id               String              @id @default(cuid())
  datasetId        String
  initiatedById    String
  uploadKey        String
  bucket           String
  originalFilename String
  mimeType         String?
  totalSizeBytes   BigInt?
  totalParts       Int
  status           UploadStatus        @default(INITIATED)
  completedAt      DateTime?
  abortedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  dataset          Dataset             @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  initiatedBy      User                @relation("UploadInitiatedBy", fields: [initiatedById], references: [id], onDelete: Cascade)
  parts            MultipartUploadPart[]
}

model MultipartUploadPart {
  id               String              @id @default(cuid())
  uploadId         String
  partNumber       Int
  etag             String?
  sizeBytes        BigInt?
  checksumSha256   String?
  uploadedAt       DateTime?

  upload           MultipartUpload     @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([uploadId, partNumber])
}

model Artifact {
  id               String              @id @default(cuid())
  datasetId        String
  jobId            String?
  kind             ArtifactKind
  title            String
  description      String?
  storageKey       String
  bucket           String
  mimeType         String
  extension        String?
  checksumSha256   String?
  sizeBytes        BigInt
  metadataJson     Json?
  createdById      String?
  createdAt        DateTime            @default(now())

  dataset          Dataset             @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  job              AnalysisJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdBy        User?               @relation("ArtifactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model AnalysisJob {
  id               String              @id @default(cuid())
  datasetId        String
  createdById      String
  type             String
  status           JobStatus           @default(QUEUED)
  stage            PipelineStage       @default(UPLOAD)
  progress         Int                 @default(0)
  inputJson        Json?
  outputJson       Json?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  dataset          Dataset             @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  createdBy        User                @relation("AnalysisJobCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  artifacts        Artifact[]
}
